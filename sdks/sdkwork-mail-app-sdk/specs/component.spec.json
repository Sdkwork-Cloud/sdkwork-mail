{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-mail-app-sdk",
    "displayName": "SDKWork Mail App SDK",
    "version": "0.1.0",
    "type": "sdk-family",
    "root": "sdkwork-mail/sdks/sdkwork-mail-app-sdk",
    "domain": "communication",
    "declaredDomain": "Mail",
    "capability": "app-sdk",
    "status": "standardizing",
    "languages": [
      "typescript",
      "rust",
      "java",
      "python",
      "go"
    ],
    "generated": true,
    "private": true,
    "manifests": [
      ".sdkwork-assembly.json"
    ]
  },
  "contracts": {
    "publicExports": [],
    "runtimeEntrypoints": [
      "bin/generate-sdk.mjs"
    ],
    "sdkClients": [],
    "sdkDependencies": [
      {
        "workspace": "sdkwork-mail-sdk",
        "role": "provider-runtime-sdk",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": null,
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/Mail-sdk",
          "rust": "sdkwork-mail-sdk",
          "java": "com.sdkwork:sdkwork-mail-sdk",
          "python": "sdkwork-mail-sdk",
          "go": "github.com/sdkwork/sdkwork-mail-sdk"
        }
      },
      {
        "workspace": "sdkwork-drive-app-sdk",
        "role": "drive-media-resource-app-capability",
        "required": true,
        "dependencyMode": "consumer-sdk",
        "apiPrefix": "/app/v3/api",
        "apiAuthority": "sdkwork-drive.app",
        "generatedTransportImportPolicy": "forbidden",
        "packageByLanguage": {
          "typescript": "@sdkwork/drive-app-sdk",
          "rust": "sdkwork-drive-app-sdk",
          "java": "com.sdkwork:sdkwork-drive-app-sdk",
          "python": "sdkwork-drive-app-sdk",
          "go": "github.com/sdkwork/sdkwork-drive-app-sdk"
        }
      }
    ],
    "events": [],
    "configKeys": [],
    "ownedOperations": [
      "mail.accounts.list",
      "mail.folders.list",
      "mail.messages.list",
      "mail.messages.create",
      "mail.messages.delete",
      "mail.messages.retrieve",
      "mail.messages.update",
      "mail.threads.list",
      "mail.transactional.send",
      "mail.verification.send",
      "mail.verification.verify"
    ]
  },
  "verification": {
    "commands": [
      "node tools/mail_sdk_generate.mjs --check --family sdkwork-mail-app-sdk"
    ]
  }
}
