{
  "name": "@sdkwork/Mail-sdk-provider-mediasoup",
  "version": "0.1.0",
  "private": true,
  "description": "Reserved TypeScript provider boundary for mediasoup Mail within sdkwork-mail-sdk",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "peerDependencies": {
    "@sdkwork/Mail-sdk": "^0.1.1"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@sdkwork/Mail-sdk": "workspace:*"
  },
  "sdkworkMailProvider": {
    "providerKey": "mediasoup",
    "displayName": "mediasoup Mail",
    "tier": "tier-c",
    "builtin": false,
    "status": "package_reference_boundary",
    "registrationContract": "MailProviderModule",
    "sourceModule": "./index.js",
    "driverFactory": "createMediasoupMailDriver",
    "metadataSymbol": "MEDIASOUP_mail_PROVIDER_METADATA",
    "moduleSymbol": "MEDIASOUP_mail_PROVIDER_MODULE",
    "rootPublic": false,
    "requiredCapabilities": [
      "session",
      "credential",
      "provider.webhook",
      "health",
      "media.audio",
      "media.video",
      "live.broadcast",
      "live.audience",
      "provider.event-normalization"
    ],
    "optionalCapabilities": [
      "data-channel",
      "provider.active-query"
    ],
    "extensionKeys": [
      "mediasoup.native-client"
    ],
    "typescriptAdapter": {
      "sdkProvisioning": "consumer-supplied",
      "bindingStrategy": "native-factory",
      "bundlePolicy": "must-not-bundle",
      "runtimeBridgeStatus": "reserved",
      "officialVendorSdkRequirement": "not-declared-until-bridge"
    }
  }
}
