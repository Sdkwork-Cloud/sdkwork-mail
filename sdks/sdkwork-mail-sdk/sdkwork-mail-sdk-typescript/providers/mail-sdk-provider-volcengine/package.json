{
  "name": "@sdkwork/Mail-sdk-provider-volcengine",
  "version": "0.1.0",
  "private": true,
  "description": "Reference TypeScript provider boundary for Volcengine Mail within sdkwork-mail-sdk",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "peerDependencies": {
    "@sdkwork/Mail-sdk": "^0.1.1",
    "@volcengine/Mail": "^4.68.3"
  },
  "peerDependenciesMeta": {
    "@volcengine/Mail": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sdkwork/Mail-sdk": "workspace:*"
  },
  "sdkworkMailProvider": {
    "providerKey": "volcengine",
    "displayName": "Volcengine Mail",
    "tier": "tier-a",
    "builtin": true,
    "status": "package_reference_boundary",
    "registrationContract": "MailProviderModule",
    "sourceModule": "./index.js",
    "driverFactory": "createVolcengineMailDriver",
    "metadataSymbol": "VOLCENGINE_mail_PROVIDER_METADATA",
    "moduleSymbol": "VOLCENGINE_mail_PROVIDER_MODULE",
    "rootPublic": false,
    "requiredCapabilities": [
      "session",
      "credential",
      "provider.webhook",
      "health",
      "media.audio",
      "media.video",
      "live.broadcast",
      "live.audience",
      "provider.event-normalization"
    ],
    "optionalCapabilities": [
      "screen-share",
      "recording",
      "artifact",
      "cloud-mix",
      "provider.active-query"
    ],
    "extensionKeys": [
      "volcengine.native-client"
    ],
    "typescriptAdapter": {
      "sdkProvisioning": "consumer-supplied",
      "bindingStrategy": "native-factory",
      "bundlePolicy": "must-not-bundle",
      "runtimeBridgeStatus": "reference-baseline",
      "officialVendorSdkRequirement": "required"
    }
  }
}
