{
  "name": "@sdkwork/Mail-sdk-provider-imap",
  "version": "0.1.0",
  "private": true,
  "description": "Reserved TypeScript provider boundary for IMAP Mail Sync within sdkwork-mail-sdk",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "peerDependencies": {
    "@sdkwork/Mail-sdk": "^0.1.1"
  },
  "peerDependenciesMeta": {},
  "devDependencies": {
    "@sdkwork/Mail-sdk": "workspace:*"
  },
  "sdkworkMailProvider": {
    "providerKey": "imap",
    "displayName": "IMAP Mail Sync",
    "tier": "tier-a",
    "builtin": true,
    "status": "package_reference_boundary",
    "registrationContract": "MailProviderModule",
    "sourceModule": "./index.js",
    "driverFactory": "createImapMailDriver",
    "metadataSymbol": "IMAP_mail_PROVIDER_METADATA",
    "moduleSymbol": "IMAP_mail_PROVIDER_MODULE",
    "rootPublic": true,
    "requiredCapabilities": [
      "transport.connect",
      "transport.authenticate",
      "health"
    ],
    "optionalCapabilities": [
      "imap.sync",
      "imap.folder-sync",
      "imap.message-sync"
    ],
    "extensionKeys": [
      "imap.sync"
    ],
    "typescriptAdapter": {
      "sdkProvisioning": "consumer-supplied",
      "bindingStrategy": "native-factory",
      "bundlePolicy": "must-not-bundle",
      "runtimeBridgeStatus": "reserved",
      "officialVendorSdkRequirement": "not-declared-until-bridge"
    }
  }
}
