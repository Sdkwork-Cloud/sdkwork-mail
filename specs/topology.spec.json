{
  "schemaVersion": 2,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-mail",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{serviceLayout}.{environment}.env",
  "vocabulary": {
    "serviceLayout": {
      "allowed": [
        "unified-process",
        "split-services"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    },
    "connectivityPlane": {
      "allowed": [
        "application",
        "platform",
        "operations"
      ]
    },
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.split-services.development",
    "productionProfileId": "cloud.split-services.production",
    "desktopBuildProfileId": "cloud.split-services.production",
    "gatewayBind": "127.0.0.1:3900"
  },
  "profileFiles": {
    "standalone.split-services.development": "configs/topology/standalone.split-services.development.env",
    "standalone.unified-process.development": "configs/topology/standalone.unified-process.development.env",
    "standalone.split-services.production": "configs/topology/standalone.split-services.production.env",
    "cloud.split-services.development": "configs/topology/cloud.split-services.development.env",
    "cloud.split-services.production": "configs/topology/cloud.split-services.production.env",
    "standalone.unified-process.production": "configs/topology/standalone.unified-process.production.env"
  },
  "envKeys": {
    "serviceLayout": "sdkwork_mail_SERVICE_LAYOUT",
    "environment": "sdkwork_mail_ENVIRONMENT",
    "profileId": "sdkwork_mail_PROFILE_ID",
    "gatewayAutostart": "sdkwork_mail_PLATFORM_API_GATEWAY_AUTOSTART",
    "standaloneGatewayBind": "sdkwork_mail_APPLICATION_PUBLIC_INGRESS_BIND",
    "cloudGatewayBind": "SDKWORK_API_CLOUD_GATEWAY_BIND",
    "cloudGatewayConfig": "SDKWORK_API_CLOUD_GATEWAY_CONFIG",
    "clientApiGatewayBaseUrl": "VITE_sdkwork_mail_PC_PLATFORM_API_GATEWAY_HTTP_URL",
    "apiGatewayBaseUrl": "sdkwork_mail_PLATFORM_API_GATEWAY_HTTP_URL",
    "deploymentProfile": "sdkwork_mail_DEPLOYMENT_PROFILE",
    "clientDeploymentProfile": "VITE_sdkwork_mail_PC_DEPLOYMENT_PROFILE"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "sdkwork_mail_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "sdkwork_mail_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_sdkwork_mail_PC_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "owner": "sdkwork-api-cloud-gateway",
      "bindEnv": "SDKWORK_API_CLOUD_GATEWAY_BIND",
      "httpUrlEnv": "sdkwork_mail_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_sdkwork_mail_PC_PLATFORM_API_GATEWAY_HTTP_URL",
      "autostartEnv": "sdkwork_mail_PLATFORM_API_GATEWAY_AUTOSTART"
    }
  },
  "cloudPublicHosts": {
    "application.public-ingress": {
      "httpHost": "Mail.sdkwork.com"
    },
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "database": {
    "appPrefix": "sdkwork_mail"
  },
  "components": {
    "applicationApiServer": {
      "crate": "sdkwork-mail-api-server",
      "binary": "sdkwork-mail-api-server"
    },
    "cloudGateway": {
      "crate": "sdkwork-api-cloud-gateway-api-server",
      "binary": "sdkwork-api-cloud-gateway",
      "repository": "sdkwork-api-cloud-gateway",
      "configGlob": "configs/sdkwork-api-cloud-gateway.sdkwork-mail.{profile}.toml"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.split-services.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-mail-api-server",
            "binary": "sdkwork-mail-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "apps/sdkwork-mail-pc",
            "script": "dev",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "standalone.unified-process.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-mail-api-server",
            "binary": "sdkwork-mail-standalone-gateway",
            "required": true
          }
        ],
        "capabilitySubset": [
          "application-http"
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.split-services.development": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": true
          },
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-mail-api-server",
            "binary": "sdkwork-mail-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "apps/sdkwork-mail-pc",
            "script": "dev",
            "required": false
          }
        ],
        "healthSurfaces": [
          "platform.api-gateway",
          "application.public-ingress"
        ]
      },
      "cloud.split-services.production": {
        "processes": [
          {
            "id": "platform.api-gateway",
            "crate": "sdkwork-api-cloud-gateway-api-server",
            "binary": "sdkwork-api-cloud-gateway",
            "repository": "sdkwork-api-cloud-gateway",
            "required": false
          },
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-mail-api-server",
            "binary": "sdkwork-mail-standalone-gateway",
            "required": true
          },
          {
            "id": "pc-renderer",
            "package": "apps/sdkwork-mail-pc",
            "script": "dev",
            "required": false
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      }
    }
  },
  "packaging": {
    "cloudConfigFiles": [
      "sdkwork-api-cloud-gateway.sdkwork-mail.development.toml",
      "sdkwork-api-cloud-gateway.sdkwork-mail.production.toml"
    ],
    "targets": [
      {
        "id": "platform-config-bundle-tar-gz",
        "profile": "platform-config-bundle",
        "platform": "all",
        "architecture": "all",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-mail-api-gateway-config-*.tar.gz"
      }
    ]
  },
  "scripts": {
    "mailDev": "scripts/mail-dev.mjs",
    "gatewayCloudBundle": "scripts/gateway-cloud-bundle.mjs"
  },
  "retired": {
    "vocabulary": {
      "topology": [
        "standalone",
        "cloud"
      ],
      "hosting": [
        "self-hosted",
        "cloud-hosted"
      ]
    },
    "envKeys": [
      "sdkwork_mail_API_BIND",
      "VITE_mail_API_BASE_URL",
      "VITE_mail_BACKEND_API_BASE_URL",
      "sdkwork_mail_HOSTING",
      "VITE_sdkwork_mail_PC_HOSTING"
    ]
  }
}
