{
  "name": "@sdkwork/mail-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm run dev:browser:postgres:split-services:standalone",
    "dev:browser:postgres:split-services:standalone": "node scripts/mail-dev.mjs --deployment-profile standalone --service-layout split-services --target pc",
    "dev:browser:postgres:split-services:cloud": "node scripts/mail-dev.mjs --deployment-profile cloud --service-layout split-services --target pc",
    "dev:browser:postgres:split-services:standalone:local": "node scripts/mail-dev.mjs --deployment-profile standalone --service-layout split-services --target h5",
    "dev:flutter-android": "node scripts/mail-dev.mjs --deployment-profile standalone --service-layout split-services --target flutter",
    "dev:server": "node scripts/mail-dev.mjs --deployment-profile standalone --service-layout split-services --target server",
    "build": "pnpm --dir apps/sdkwork-mail-pc build && cargo build --workspace",
    "check": "pnpm run check:app-composition && pnpm run test:workspace-standard && pnpm run test:contract:database && pnpm run typecheck && cargo check --workspace",
    "clean": "node -e \"const fs=require('fs'); for (const dir of ['dist','target']) { try { fs.rmSync(dir,{recursive:true,force:true}); } catch {} }\"",
    "test:contract:migration": "node --test tests/mail-migration-contract.test.mjs",
    "api:materialize": "node tools/materialize-mail-openapi-envelope.mjs",
    "api:materialize:rust-component-specs": "node tools/materialize-mail-rust-component-specs.mjs",
    "api:materialize:check": "node tools/materialize-mail-rust-component-specs.mjs --check",
    "workflow:prepare-ci-dependencies": "node scripts/prepare-ci-dependencies.mjs",
    "sdk:check": "node tools/mail_sdk_generate.mjs --check",
    "sdk:build": "pnpm --dir sdks/sdkwork-mail-app-sdk/sdkwork-mail-app-sdk-typescript/generated/server-openapi run build && pnpm --dir sdks/sdkwork-mail-backend-sdk/sdkwork-mail-backend-sdk-typescript/generated/server-openapi run build",
    "test:workspace-standard": "node --test tests/mail-workspace-standard.test.mjs",
    "test": "vitest run apps/sdkwork-mail-pc/packages/sdkwork-mail-pc-mail/tests apps/sdkwork-mail-pc/src/__tests__/pc-architecture.contract.test.ts apps/sdkwork-mail-h5/src/__tests__/h5-architecture.contract.test.ts",
    "test:h5-typecheck": "pnpm --dir apps/sdkwork-mail-h5 run typecheck",
    "test:rust": "cargo test --workspace",
    "test:flutter-analyze": "cd apps/sdkwork-mail-flutter-mobile && flutter analyze",
    "test:flutter": "cd apps/sdkwork-mail-flutter-mobile && flutter test",
    "test:mini-program": "cd apps/sdkwork-mail-mini-program && pnpm run build && pnpm run typecheck && node --test tests/mail-mp-runtime.test.mjs",
    "test:rust-fmt": "cargo fmt --check",
    "test:topology-validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "test:topology-contract": "node --test tests/mail-topology-contract.test.mjs",
    "test:topology-baggage": "node --test tests/mail-topology-baggage.test.mjs",
    "test:topology-packaging": "node scripts/gateway-cloud-bundle.mjs bundle --version 0.0.0-test && node scripts/gateway-cloud-bundle.mjs validate --version 0.0.0-test",
    "gateway:package:cloud": "node scripts/gateway-cloud-bundle.mjs bundle",
    "gateway:validate:cloud": "node scripts/gateway-cloud-bundle.mjs validate",
    "gateway:matrix:cloud": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs print-matrix --root . --spec specs/topology.spec.json --profile platform-config-bundle",
    "gateway:matrix": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs print-matrix --root . --spec specs/topology.spec.json --profile all",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm run test:workspace-standard && pnpm run test:contract:migration && pnpm run test:contract:database && pnpm run api:materialize && pnpm run test:contract:api-envelope && pnpm run sdk:check && pnpm run sdk:build && pnpm run typecheck && cargo check --workspace && pnpm run test:rust-fmt && pnpm run test:topology-contract && pnpm run test:topology-validate && pnpm run test:topology-baggage && pnpm run check:app-composition",
    "test:contract:api-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_mail_baseline.sql --module-id mail --owner mail-platform --prefixes mail_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "test:contract:database": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
  },
  "dependencies": {
    "@sdkwork/app-topology": "workspace:*"
  },
  "devDependencies": {
    "@sdkwork/utils": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.8"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
