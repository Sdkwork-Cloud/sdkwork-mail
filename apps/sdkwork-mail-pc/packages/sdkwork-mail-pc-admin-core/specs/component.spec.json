{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-mail-pc-admin-core",
    "displayName": "SDKWork Mail PC Admin Core",
    "version": "0.1.0",
    "type": "react-package",
    "root": "sdkwork-mail/apps/sdkwork-mail-pc/packages/sdkwork-mail-pc-admin-core",
    "domain": "communication",
    "declaredDomain": "communication",
    "capability": "admin-core",
    "status": "ready",
    "languages": [
      "typescript"
    ],
    "generated": false,
    "private": true,
    "manifests": [
      "package.json"
    ]
  },
  "contracts": {
    "publicExports": [
      "."
    ],
    "sdkClients": [
      "@sdkwork/mail-backend-sdk"
    ],
    "sdkDependencies": [
      {
        "workspace": "sdkwork-mail-backend-sdk",
        "surface": "backend-api",
        "credentialMode": "authenticated-backend-admin"
      }
    ],
    "permissionComposition": {
      "inheritanceMode": "module-catalog-with-overrides",
      "applicationModule": {
        "manifestRef": "../../../../../specs/iam.module.manifest.json"
      },
      "moduleCatalogRefs": [
        {
          "moduleId": "mail",
          "manifestRef": "../../../../../specs/iam.module.manifest.json",
          "inheritPermissions": true,
          "inheritRoles": true
        }
      ],
      "bootstrapAccessTokenScope": {
        "inheritFrom": "sdkwork.app.config.json#backend.accessTokenPermissionScope",
        "supplement": [],
        "overrideReplace": false
      },
      "routePermissionHints": {
        "inheritFromOpenApi": true,
        "inheritFromModuleManifests": true,
        "overrides": []
      },
      "consumerPolicy": {
        "forbidLocalPermissionCatalogForDependencyDomains": true,
        "allowExplicitOverridesOnly": true,
        "allowFrontendHintsWithoutServerDuplication": true
      }
    }
  }
}
