.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.hint,
.empty {
  display: block;
  color: #64748b;
  margin-bottom: 16rpx;
}

.field {
  display: block;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1px solid #cbd5e1;
  border-radius: 12rpx;
}

.picker {
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1px solid #cbd5e1;
  border-radius: 12rpx;
  color: #334155;
}

.session {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1px solid #e2e8f0;
}

.error {
  display: block;
  color: #b91c1c;
  margin: 12rpx 0;
}

.session-title {
  display: block;
  font-weight: 600;
}

.session-mode {
  display: block;
  color: #64748b;
  font-size: 24rpx;
}

.status {
  color: #0f766e;
}
