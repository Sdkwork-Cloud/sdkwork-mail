.meta,
.hint,
.join-message {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.field {
  display: block;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1px solid #cbd5e1;
  border-radius: 12rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.error {
  color: #b91c1c;
}

.primary {
  margin-top: 8rpx;
}
