.card {
  margin-top: 80rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  color: #64748b;
  margin-bottom: 24rpx;
}

.field {
  display: block;
  margin-bottom: 16rpx;
  padding: 20rpx;
  border: 1px solid #cbd5e1;
  border-radius: 12rpx;
}

.primary {
  margin-top: 16rpx;
}
