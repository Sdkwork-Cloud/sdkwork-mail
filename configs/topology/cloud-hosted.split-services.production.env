# RTC topology profile: cloud-hosted + split-services + production

SDKWORK_RTC_HOSTING=cloud-hosted
SDKWORK_RTC_SERVICE_LAYOUT=split-services
SDKWORK_RTC_ENVIRONMENT=production
SDKWORK_RTC_PROFILE_ID=cloud-hosted.split-services.production

SDKWORK_RTC_APPLICATION_PUBLIC_INGRESS_BIND=0.0.0.0:8080
SDKWORK_RTC_APPLICATION_PUBLIC_HTTP_URL=https://rtc.sdkwork.com

SDKWORK_API_GATEWAY_BIND=0.0.0.0:3900
SDKWORK_RTC_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
SDKWORK_RTC_PLATFORM_API_GATEWAY_AUTOSTART=false

VITE_SDKWORK_RTC_PC_HOSTING=cloud-hosted
VITE_SDKWORK_RTC_PC_ENVIRONMENT=production
VITE_SDKWORK_RTC_PC_APPLICATION_PUBLIC_HTTP_URL=https://rtc.sdkwork.com
VITE_SDKWORK_RTC_PC_APP_API_BASE_URL=https://rtc.sdkwork.com/app/v3/api
VITE_SDKWORK_RTC_PC_BACKEND_API_BASE_URL=https://rtc.sdkwork.com/backend/v3/api
VITE_SDKWORK_RTC_PC_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

VITE_SDKWORK_RTC_H5_APPLICATION_PUBLIC_HTTP_URL=https://rtc.sdkwork.com
VITE_SDKWORK_RTC_H5_APP_API_BASE_URL=https://rtc.sdkwork.com/app/v3/api
VITE_SDKWORK_RTC_H5_BACKEND_API_BASE_URL=https://rtc.sdkwork.com/backend/v3/api
VITE_SDKWORK_RTC_H5_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com

SDKWORK_RTC_APPLICATION_PUBLIC_HTTP_URL=https://rtc.sdkwork.com
SDKWORK_RTC_APP_API_BASE_URL=https://rtc.sdkwork.com/app/v3/api
SDKWORK_RTC_BACKEND_API_BASE_URL=https://rtc.sdkwork.com/backend/v3/api
SDKWORK_RTC_PLATFORM_API_GATEWAY_HTTP_URL=https://api.sdkwork.com
