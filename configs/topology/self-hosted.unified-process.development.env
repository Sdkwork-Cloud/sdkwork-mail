# RTC topology profile: self-hosted + unified-process + development (smoke)

SDKWORK_RTC_HOSTING=self-hosted
SDKWORK_RTC_SERVICE_LAYOUT=unified-process
SDKWORK_RTC_ENVIRONMENT=development
SDKWORK_RTC_PROFILE_ID=self-hosted.unified-process.development

SDKWORK_RTC_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18088
