{
  "provider": "agora",
  "displayName": "Agora Mail",
  "description": "Agora实时音视频Mail提供方",
  "accountFields": [
    {"key": "externalTenantId", "label": "Agora Account ID", "type": "string", "required": false}
  ],
  "applicationFields": [
    {"key": "providerApplicationId", "label": "App ID", "type": "string", "required": true, "placeholder": "如 a]1234567890abcdef"},
    {"key": "providerApplicationIdKind", "label": "应用ID类型", "type": "enum", "values": ["app_id"], "default": "app_id", "hidden": true},
    {"key": "accessEndpoint", "label": "接入端点", "type": "string", "default": "wss://Mail.agora.local/session", "required": false}
  ],
  "credentialRoles": [
    {
      "role": "mail_token_signing",
      "label": "Mail Token签名",
      "description": "用于生成参与者凭证(Mail Token)",
      "fields": [
        {"key": "credentialRef", "label": "App Certificate", "type": "secret_ref", "required": true, "placeholder": "secret://Mail/agora/app-certificate"}
      ]
    }
  ],
  "profileFields": [
    {"key": "providerAppId", "label": "App ID", "type": "string", "required": true},
    {"key": "endpoint", "label": "接入端点", "type": "string", "default": "wss://Mail.agora.local/session"},
    {"key": "region", "label": "区域", "type": "enum", "values": ["global", "cn", "na", "eu", "ap"], "default": "global"},
    {"key": "credentialTtlSeconds", "label": "凭证有效期(秒)", "type": "number", "default": 3600, "min": 300, "max": 86400}
  ],
  "optionalCapabilities": ["recording", "artifact", "screen-share", "cloud-mix", "data-channel", "spatial-audio", "e2ee", "provider.active-query"],
  "requiredCapabilities": ["session", "credential", "provider.webhook", "health", "media.audio", "media.video", "live.broadcast", "live.audience", "provider.event-normalization"]
}
