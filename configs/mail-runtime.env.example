# Safe Mail runtime defaults for local development and tests.
# Topology bind: see configs/topology/*.env and specs/topology.spec.json.
SDKWORK_MAIL_APP_CONTEXT_REQUIRE_SIGNATURE=false
SDKWORK_MAIL_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:18090
# Optional Postgres persistence for mail state. Persistence is opt-in.
# SDKWORK_MAIL_DATABASE_URL=postgres://mail:mail@127.0.0.1:5432/mail
# SDKWORK_MAIL_HYDRATE_TENANT_ID=default
# SDKWORK_MAIL_HYDRATE_ORGANIZATION_ID=default

# IMAP transport plugin (optional)
# SDKWORK_MAIL_IMAP_HOST=imap.example.com
# SDKWORK_MAIL_IMAP_PORT=993
# SDKWORK_MAIL_IMAP_USE_TLS=true

# SMTP transport plugin (optional)
# SDKWORK_MAIL_SMTP_HOST=smtp.example.com
# SDKWORK_MAIL_SMTP_PORT=587
# SDKWORK_MAIL_SMTP_USE_TLS=true
