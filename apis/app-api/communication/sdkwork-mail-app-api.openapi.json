  "components": {
    "securitySchemes": {
      "AuthToken": {
        "type": "http",
        "scheme": "bearer"
      },
      "AccessToken": {
        "type": "apiKey",
        "in": "header",
        "name": "Access-Token"
      }
    },
    "schemas": {
      "ProblemDetail": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "type",
          "title",
          "status",
          "code",
          "traceId"
        ],
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string"
          },
          "code": {
            "$ref": "#/components/schemas/SdkWorkPlatformErrorCode"
          },
          "traceId": {
            "type": "string",
            "format": "uuid",
            "description": "Server-owned request correlation id."
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FieldError"
            }
          }
        }
      },
      "MailAccount": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "emailAddress": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "providerKind": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "syncEnabled": {
            "type": "boolean"
          }
        }
      },
      "MailFolder": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "folderKind": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "unreadCount": {
            "type": "integer"
          },
          "totalCount": {
            "type": "integer"
          }
        }
      },
      "MailThread": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "folderId": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "messageCount": {
            "type": "integer"
          },
          "unreadCount": {
            "type": "integer"
          },
          "isStarred": {
            "type": "boolean"
          }
        }
      },
      "MailMessage": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "accountId": {
            "type": "string"
          },
          "folderId": {
            "type": "string"
          },
          "threadId": {
            "type": "string"
          },
          "fromEmail": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "bodyText": {
            "type": "string"
          },
          "bodyHtml": {
            "type": "string"
          },
          "isRead": {
            "type": "boolean"
          },
          "isStarred": {
            "type": "boolean"
          },
          "isDraft": {
            "type": "boolean"
          },
          "hasAttachments": {
            "type": "boolean"
          }
        }
      },
      "CreateMailMessageRequest": {
        "type": "object",
        "required": [
          "accountId",
          "subject"
        ],
        "properties": {
          "accountId": {
            "type": "string"
          },
          "folderId": {
            "type": "string"
          },
          "threadId": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "bodyText": {
            "type": "string"
          },
          "bodyHtml": {
            "type": "string"
          },
          "isDraft": {
            "type": "boolean"
          },
          "attachments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateMailAttachmentInput"
            }
          }
        }
      },
      "CreateMailAttachmentInput": {
